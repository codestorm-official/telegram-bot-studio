BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
LOG_LEVEL=INFO

# PostgreSQL connection string (Railway exposes this as DATABASE_URL).
# Optional: leave empty or remove to run without persistence (local testing).
# Local example: postgresql://postgres:postgres@localhost:5432/botdb
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Redis connection string (Railway exposes this as REDIS_URL).
# Optional: leave empty or remove to run without caching (local testing).
# Local example: redis://localhost:6379/0
REDIS_URL=redis://HOST:6379/0

# Admin panel (Bot Panel UI) for managing dynamic commands.
# The panel is served only when PANEL_PASSWORD is set; without it the bot runs
# as a plain poller. Requires DATABASE_URL to store commands.
PANEL_USERNAME=admin
PANEL_PASSWORD=
# Optional: stable secret for signing session cookies. If empty, a value is
# derived from PANEL_PASSWORD. Set your own to rotate sessions independently.
PANEL_SECRET_KEY=
# Port the panel binds to. Railway injects PORT automatically; default 8080 locally.
PORT=8080
